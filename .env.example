# Copy this file to .env at the repo root and fill in values.

# --- Database ---
# Default: SQLite — zero setup, file lives at packages/db/dev.db.
DATABASE_URL="file:./dev.db"
# For Postgres (Neon, Railway, docker-compose), use a connection string instead:
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?schema=public"

# --- Auth ---
# 32+ random characters. Generate with: openssl rand -base64 48
SESSION_SECRET="change-me-to-a-long-random-string"

# --- Origins (used for CORS + cookies) ---
WEB_ORIGIN="http://localhost:3000"
API_ORIGIN="http://localhost:4000"

# --- Jamendo (free CC catalog) ---
# Register at https://devportal.jamendo.com/ — free tier is generous.
JAMENDO_CLIENT_ID=""

# --- Cloudflare R2 (object storage for uploads) ---
# Leave blank to disable upload feature; the rest of the app still runs.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="resonate-tracks"
R2_PUBLIC_URL=""

# --- Redis (used by listening rooms in Phase 3) ---
REDIS_URL="redis://localhost:6379"

NODE_ENV="development"
