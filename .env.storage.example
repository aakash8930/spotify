# --- Object storage ---
# Two ways to configure storage:
#
# 1. Cloudflare R2 (production-ready, free egress):
#    Get keys at https://dash.cloudflare.com/?to=/:account/r2/api-tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="resonate-tracks"
# Public URL for the bucket — required so audio links are playable in the browser.
# Either R2 public access (https://pub-xxx.r2.dev) or a custom domain.
R2_PUBLIC_URL=""
#
# 2. MinIO via docker-compose (local dev). Uncomment these instead of R2_*.
#    The bucket is auto-created on API startup.
# S3_ENDPOINT="http://localhost:9000"
# R2_ACCESS_KEY_ID="resonate"
# R2_SECRET_ACCESS_KEY="resonate-dev"
# R2_BUCKET="resonate-tracks"
# R2_PUBLIC_URL="http://localhost:9000/resonate-tracks"
